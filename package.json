{
  "name": "medusa-payment-iyzico",
  "version": "0.0.1",
  "description": "Iyzico payment provider plugin for MedusaJS v2 — preauth/capture lifecycle (AbstractPaymentProvider) over the iyzipay SDK. The first Iyzico provider for Medusa v2.",
  "author": "Enes Ozdemir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enesoz/medusa-payment-iyzico.git"
  },
  "bugs": {
    "url": "https://github.com/enesoz/medusa-payment-iyzico/issues"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-payment",
    "medusa-plugin",
    "medusa-v2",
    "iyzico",
    "iyzipay",
    "payment-provider",
    "turkey"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch(e){}\"",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/icons": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/test-utils": "2.15.5",
    "@medusajs/ui": "4.1.15",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/icons": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/test-utils": "2.15.5",
    "@medusajs/ui": "4.1.15"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
